# ─────────────────────────────────────────────
# Web Way — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ─────────────────────────────────────────────

# ── Banco de dados ──────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webway"

# ── Autenticação ────────────────────────────
# String aleatória longa (mínimo 32 chars). Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="troque-por-uma-string-aleatoria-longa-aqui"

# Dias até a sessão expirar (padrão: 30)
SESSION_EXPIRY_DAYS=30

# ── Aplicação ───────────────────────────────
# URL pública da aplicação (sem trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Ambiente: development | production | test
NODE_ENV="development"

# ── Storage ─────────────────────────────────
# Provedor de storage: local | s3 | r2 | minio
STORAGE_PROVIDER="local"

# Diretório de uploads locais (relativo ao projeto)
# Só usado quando STORAGE_PROVIDER=local
UPLOAD_DIR="./public/uploads"
NEXT_PUBLIC_UPLOADS_URL="/uploads"

# ── Storage S3 (opcional, para produção) ────
# Preencha apenas se STORAGE_PROVIDER=s3
# S3_BUCKET=""
# S3_REGION="us-east-1"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""       # Para R2/MinIO: endpoint customizado

# ── Docker Compose ──────────────────────────
# Usadas apenas pelo docker-compose.yml
POSTGRES_PASSWORD="postgres"

# ── Opcional ────────────────────────────────
# Email para alertas (futuro)
# ALERT_EMAIL=""

# Google Analytics (futuro)
# NEXT_PUBLIC_GA_ID=""
